# Copy this file to .env and fill in the values before starting the server.

# Required. Must be at least 32 characters. Used to sign JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Optional. Defaults to 3001.
PORT=3001

# Optional. Allowed CORS origin for the frontend. Defaults to http://localhost:5173.
CORS_ORIGIN=http://localhost:5173
